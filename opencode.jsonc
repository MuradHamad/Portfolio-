{
  "$schema": "https://opencode.ai/config.json",

  // ── Model ──────────────────────────────────────────────────────────────────
  // Format: "providerKey/modelId" — providerKey must match the key below
  // Gemini 2.5 Flash: best budget model for UI/frontend vibe coding
  // To switch models for harder problems, change to:
  // "openrouter/google/gemini-2.5-pro"     ← more powerful, more expensive
  // "openrouter/anthropic/claude-sonnet-4" ← best quality, most expensive
  "model": "openrouter/google/gemini-2.5-flash",

  // ── Provider ───────────────────────────────────────────────────────────────
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      // Models you want available — switch between them using /models in OpenCode
      "models": {
        "google/gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash"
        },
        "google/gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro"
        },
        "anthropic/claude-sonnet-4": {
          "name": "Claude Sonnet 4"
        }
      }
    }
  },

  // ── MCP Servers ────────────────────────────────────────────────────────────
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-75fde233-57d5-4f34-97c7-bbbffc6f080e"
      },
      "enabled": true
    }
  },

  // ── Permissions ────────────────────────────────────────────────────────────
  "permission": {
    "edit": "allow",
    "bash": {
      "npm *": "allow",
      "git *": "allow",
      "npx *": "allow",
      "rm -rf *": "ask",
      "*": "ask"
    }
  },

  "autoupdate": true
}
